{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=C:\\AYDB\\smart.db;Cache=Shared;",
    "TaskQueueConnection": "Data Source=C:\\AYDB\\tq.db;Cache=Shared;"
  },
  "MigrationsAssembly": "AY.SmartEngine.Infrastructure.Migrations.SQLite",
  "TaskQueueMigrationsAssembly": "AY.SmartEngine.Infrastructure.TaskQueue.Migrations.SQLite",
  "Serilog": {
    //加载 Sink 组件，因为配置文件是反射加载，不写就找不到 Sink。Debug：输出到 VS 调试窗口
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File", "Serilog.Sinks.Async", "Serilog.Sinks.Debug" ],
    "MinimumLevel": {
      "Default": "Information",
      //针对特定“命名空间”单独设置
      "Override": {
        // 必须确保这个级别是 Information 或 Debug，因为 SQL 执行属于 Information
        "Microsoft.EntityFrameworkCore.Database.Command": "Debug",
        //应用启动/停止日志
        "Microsoft.Hosting.Lifetime": "Information",
        //过滤掉框架内部大量 Info 日志，否则日志会被刷爆
        "Microsoft": "Warning",
        "System": "Warning",
        "System.Net.Http": "Warning"
      }
    },
    //日志增强配置：自动给每条日志加“维度信息”
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId",
      "WithProcessId",
      "WithProcessName",
      "WithEnvironmentName"
    ],
    //配置多个输出管道：同时输出到文件、控制台、和VS输出窗口
    "WriteTo": [
      {
        //输出到：Visual Studio “输出窗口”
        "Name": "Debug",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] <{ThreadId}> {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        //输出到：控制台
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] <{ThreadId}> {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        //异步输出到文件
        "Name": "Async",
        "Args": {
          "configure": [
            {
              "Name": "File",
              "Args": {
                "path": "Logs/app-all-.log",
                "rollingInterval": "Day",
                "retainedFileCountLimit": 14,
                "fileSizeLimitBytes": 10485760,
                "rollOnFileSizeLimit": true,
                "shared": true,
                "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff} [{Level:u3}] [{ThreadId}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
              }
            }
          ]
        }
      },
      {
        "Name": "Async",
        "Args": {
          "configure": [
            {
              "Name": "File",
              "Args": {
                "path": "Logs/app-error-.log",
                "restrictedToMinimumLevel": "Error",
                "rollingInterval": "Day",
                "retainedFileCountLimit": 30,
                "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff} [{Level:u3}] [{ProcessId}-{ThreadId}] {SourceContext}{NewLine}Message: {Message:lj}{NewLine}{Exception}{Data}{NewLine}"
              }
            }
          ]
        }
      }
    ]
  }
}
